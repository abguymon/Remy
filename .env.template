# Remy v2 configuration. Copy to .env and fill in.
# See PRD.md §8 for the authoritative list.

# --- Auth & crypto (REQUIRED — the API refuses to boot without real values) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Fernet key for encrypting Kroger tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Kroger API (register at https://developer.kroger.com/) ---
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
# OAuth redirect back to the API's callback route.
# e.g. https://remy.example.com/api/kroger/callback
KROGER_REDIRECT_URI=http://localhost:8080/kroger/callback

# --- LLM (provider-agnostic via LiteLLM) ---
# LLM_PROVIDER: anthropic | openai | ... ; LLM_MODEL: a current top-tier model id.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
# Provider API key (name matches the chosen provider).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Web search (pluggable provider) ---
# SEARCH_PROVIDER: brave | serper | llm
SEARCH_PROVIDER=brave
SEARCH_API_KEY=

# --- MCP facade (agent interface) ---
MCP_FACADE_ENABLED=true
