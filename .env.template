# Remy v2 configuration. Copy to .env and fill in.
# See PRD.md §8 for the authoritative list.

# --- Auth & crypto (REQUIRED — the API refuses to boot without real values) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Fernet key for encrypting Kroger tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Kroger API (register at https://developer.kroger.com/) ---
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
# OAuth redirect back to the API's callback route.
# e.g. https://remy.example.com/api/kroger/callback
KROGER_REDIRECT_URI=http://localhost:8080/kroger/callback

# --- LLM (provider-agnostic via LiteLLM) ---
# LLM_PROVIDER: anthropic | openai | ... ; LLM_MODEL: a current top-tier model id.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
# Provider API key (name matches the chosen provider).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Langfuse Cloud observability (optional) ---
# Create a project at https://us.cloud.langfuse.com and copy its API keys.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_ENVIRONMENT=production
# Cost, token, latency, user, session, and prompt-version metadata are recorded
# without content. Set true only if you want prompts/responses stored in Cloud.
LANGFUSE_CAPTURE_CONTENT=false

# --- Web search (pluggable provider) ---
# SEARCH_PROVIDER: searxng (default, self-hosted, no API key) | brave | llm
SEARCH_PROVIDER=searxng
# Brave/LLM only: your Brave Search API key (unused for searxng).
SEARCH_API_KEY=

# SearXNG (self-hosted): the compose stack runs a `searxng` service on remy-net.
SEARXNG_URL=http://searxng:8080
# Secret key for the SearXNG instance. Generate once with:
#   openssl rand -hex 32     (or: python -c "import secrets; print(secrets.token_hex(32))")
SEARXNG_SECRET=

# --- MCP facade (agent interface) ---
MCP_FACADE_ENABLED=true
# Optional DNS-rebinding protection for the /mcp endpoint. Leave empty to rely on
# the reverse proxy + bearer-token auth; set to your deploy host/origin to enable
# strict checks (comma- or JSON-list), e.g. MCP_ALLOWED_HOSTS=["remy.example.com"].
# MCP_ALLOWED_HOSTS=
# MCP_ALLOWED_ORIGINS=

# Web app origin for OAuth-return redirects. Leave empty in single-origin
# production (Traefik). Set to http://localhost:3000 for split-origin dev.
WEB_APP_URL=
